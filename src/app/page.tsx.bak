"use client";
import Link from "next/link";
import { useEffect, useRef, useState } from "react";
import { ArrowRight, Check, BookOpen, Lock, Users, Star, Shield, Send } from "lucide-react";

// ── Waitlist form ───────────────────────────────────────────────────────────────
function WaitlistForm({ compact = false }: { compact?: boolean }) {
  const [email, setEmail] = useState("");
  const [submitted, setSubmitted] = useState(false);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault();
    if (!email.trim()) return;
    setLoading(true);
    setError("");
    try {
      const res = await fetch("/api/grove/waitlist", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email: email.trim() }),
      });
      if (!res.ok) throw new Error("Failed");
      setSubmitted(true);
      // Fire Meta Pixel Lead event
      if (typeof window !== "undefined") {
        const w = window as unknown as { fbq?: (...args: unknown[]) => void };
        if (w.fbq) w.fbq("track", "Lead");
      }
    } catch (_err) {
      setError("Something went wrong. Try again.");
    } finally {
      setLoading(false);
    }
  }

  if (submitted) {
    return (
      <div style={{
        padding: compact ? "20px 24px" : "28px 32px",
        background: "var(--green-light)",
        border: "1.5px solid var(--green-border)",
        borderRadius: 16,
        textAlign: "center",
        animation: "fadeIn 0.4s ease both",
      }}>
        <p style={{ fontSize: 20, marginBottom: 6 }}>🌿</p>
        <p style={{ fontFamily: "var(--font-playfair)", fontWeight: 700, fontSize: compact ? 16 : 18, color: "var(--green)", marginBottom: 6 }}>
          You&apos;re on the list.
        </p>
        <p style={{ fontSize: 14, color: "var(--text-2)", lineHeight: 1.6 }}>
          We&apos;ll reach out to founding families first. Tell a friend who&apos;s expecting.
        </p>
      </div>
    );
  }

  return (
    <form onSubmit={handleSubmit} style={{ width: "100%" }}>
      <div style={{ display: "flex", gap: 10, flexWrap: "wrap" }}>
        <input
          type="email"
          required
          placeholder="Your email address"
          value={email}
          onChange={e => setEmail(e.target.value)}
          style={{
            flex: "1 1 240px",
            padding: compact ? "12px 16px" : "15px 18px",
            borderRadius: 10,
            border: "1.5px solid var(--border)",
            background: "var(--bg)",
            color: "var(--text)",
            fontSize: 15,
            outline: "none",
            fontFamily: "inherit",
          }}
        />
        <button
          type="submit"
          disabled={loading}
          className="btn-primary"
          style={{ padding: compact ? "12px 22px" : "15px 26px", fontSize: 15, whiteSpace: "nowrap", opacity: loading ? 0.7 : 1 }}
        >
          {loading ? "Saving…" : "Reserve your spot"}
        </button>
      </div>
      {error && <p style={{ marginTop: 8, fontSize: 13, color: "#c0392b" }}>{error}</p>}
    </form>
  );
}

function Reveal({ children, delay = 0, style = {} }: {
  children: React.ReactNode; delay?: number; style?: React.CSSProperties;
}) {
  const ref = useRef<HTMLDivElement>(null);
  const [done, setDone] = useState(false);
  useEffect(() => {
    const timer = setTimeout(() => {
      const el = ref.current;
      if (!el) return;
      const obs = new IntersectionObserver(
        ([e]) => { if (e.isIntersecting) { setDone(true); obs.disconnect(); } },
        { threshold: 0.01, rootMargin: "120px 0px 120px 0px" }
      );
      obs.observe(el);
    }, 40);
    return () => clearTimeout(timer);
  }, []);
  return (
    <div ref={ref} style={{
      animation: done ? `revealUp 0.55s cubic-bezier(0.4,0,0.2,1) ${delay}ms both` : undefined,
      ...style,
    }}>
      {children}
    </div>
  );
}

const STEPS = [
  { n: "01", title: "Tell Our Fable about your child.", body: "Name, birthday, a family password. Five minutes. Our Fable builds their private Vault, their circle, and their world snapshot — ready instantly." },
  { n: "02", title: "Add the people who love them.", body: "Grandparents, aunts, uncles, godparents, best friends. Each person gets a unique link. No account. No app. Just a link." },
  { n: "03", title: "Our Fable asks every circle member, every month.", body: "A personal prompt goes out automatically — different for each relationship. Grandma gets a different question than the college roommate. They respond with text, a photo, a voice memo, or a video." },
  { n: "04", title: "Everything seals in the Vault.", body: "Every response is stored and time-locked. Some open at 13. Some at 18. Some on graduation day, or their wedding. The people who love them, speaking directly across time." },
];

const FEATURES = [
  { icon: Lock, title: "The Vault", body: "Every response from every circle member — photos, videos, voice memos, letters — sealed and waiting. Age-gated and delivered at the moments that matter. 13. 18. Graduation. Wedding day." },
  { icon: Users, title: "Monthly Prompts", body: "Our Fable interviews the people in your child's life automatically. Tailored to each relationship, sent every month. All they do is reply." },
  { icon: Send, title: "Outgoings", body: "Send photos, videos, letters, or updates to your whole circle — or just select a few. One send, everyone who matters gets it. No group chat. No social media. Just the people who love them." },
  { icon: BookOpen, title: "Monthly World Snapshot", body: "Once a month, Our Fable captures the world your child was born into — the top news story, the weather, the #1 song, the market close. One page per month of their life. At 18, they have 216 of them." },
  { icon: Star, title: "The Day They Were Born", body: "A permanent front page for their birthday — everything happening in the world on the day they arrived. Something they'll actually want to read someday." },
];

