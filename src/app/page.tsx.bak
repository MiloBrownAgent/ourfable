            <p style={{ fontSize: 16, color: "rgba(255,255,255,0.65)", lineHeight: 1.75, maxWidth: 520, margin: "0 auto" }}>
              Our Fable makes this happen because once a month, it asked. She answered. Her voice is in the Vault — sealed, waiting for the moment your child is ready to hear it.
            </p>
          </div>
        </Reveal>
      </section>

      {/* ── SECURITY ── */}
      <section style={{ padding: "100px 40px", maxWidth: 960, margin: "0 auto" }}>
        <Reveal>
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 64, alignItems: "center", marginBottom: 56 }} className="security-intro">
            <div>
              <p className="label label-green" style={{ marginBottom: 14 }}>Privacy</p>
              <h2 style={{ fontFamily: "var(--font-playfair)", fontSize: "clamp(1.8rem, 3vw, 2.6rem)", fontWeight: 800, letterSpacing: "-0.025em", lineHeight: 1.2, marginBottom: 16 }}>
                Private by design.<br />Not by policy.
              </h2>
              <p style={{ fontSize: 16, color: "var(--text-2)", lineHeight: 1.75 }}>
                This is not a social network with a private mode. Our Fable was built from day one to never be public. Your child's story belongs to your family — not to an algorithm, not to advertisers, not to anyone.
              </p>
            </div>
            <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
              {[
                { icon: Shield, text: "No public profiles or search results. Every page blocks search engines." },
                { icon: Lock, text: "Letters are sealed on our servers. Not even parents can read them before the date." },
                { icon: Check, text: "Each circle member has their own unique link. No shared access. No accounts to create." },
              ].map((item, i) => {
                const Icon = item.icon;
                return (
                  <div key={i} style={{ display: "flex", gap: 14, alignItems: "flex-start", padding: "16px 18px", background: "var(--card)", border: "1.5px solid var(--border)", borderRadius: 12 }}>
                    <div style={{ width: 32, height: 32, borderRadius: 8, background: "var(--green-light)", border: "1px solid var(--green-border)", display: "flex", alignItems: "center", justifyContent: "center", flexShrink: 0 }}>
                      <Icon size={14} color="var(--green)" strokeWidth={2} />
                    </div>
                    <p style={{ fontSize: 14, lineHeight: 1.65, color: "var(--text-2)", paddingTop: 2 }}>{item.text}</p>
                  </div>
                );
              })}
            </div>
          </div>
        </Reveal>

        <Reveal delay={100}>
          <div className="security-grid" style={{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: 10 }}>
            {[
              { title: "Rate-limited auth", body: "Login attempts are limited to 5 per 15 minutes per device." },
              { title: "Session security", body: "Auth uses cryptographically signed tokens. No third-party services involved." },
              { title: "No tracking, no ads", body: "Zero analytics reporting to third parties. Your child's data is never sold or shared." },
            ].map((item) => (
              <div key={item.title} style={{ padding: "18px 18px", background: "var(--bg-2)", border: "1px solid var(--border)", borderRadius: 10 }}>
                <p style={{ fontSize: 13, fontWeight: 600, color: "var(--text)", marginBottom: 4 }}>{item.title}</p>
                <p style={{ fontSize: 13, lineHeight: 1.65, color: "var(--text-2)" }}>{item.body}</p>
              </div>
            ))}
          </div>
        </Reveal>
      </section>

      {/* ── FINAL CTA ── */}
      <section style={{ padding: "80px 40px 140px", textAlign: "center" }}>
        <Reveal>
          <div style={{ maxWidth: 600, margin: "0 auto" }}>
            <p style={{ fontFamily: "var(--font-playfair)", fontStyle: "italic", fontSize: "clamp(1.1rem, 2vw, 1.4rem)", color: "var(--text-3)", marginBottom: 24, lineHeight: 1.6 }}>
              "The people who love your child won't be here forever."
            </p>
            <h2 style={{ fontFamily: "var(--font-playfair)", fontWeight: 800, fontSize: "clamp(2.5rem, 5vw, 4rem)", letterSpacing: "-0.025em", lineHeight: 1.1, marginBottom: 20 }}>
              Start{" "}
              <em style={{ color: "var(--green)", fontStyle: "italic" }}>their</em>
              {" "}story.
            </h2>
            <p style={{ fontSize: 17, color: "var(--text-2)", marginBottom: 40, lineHeight: 1.7 }}>
              Five minutes to set up. Our Fable interviews them every month — and holds every answer until your child is ready.
            </p>
            <div style={{ maxWidth: 480, margin: "0 auto" }}>
              <WaitlistForm />
            </div>
            <p style={{ marginTop: 14, fontSize: 13, color: "var(--text-3)" }}>Founding families only · First access · No credit card</p>
          </div>
        </Reveal>
      </section>

      {/* ── FOOTER ── */}
      <footer style={{ borderTop: "1px solid var(--border)", padding: "32px 40px", background: "var(--bg-2)" }}>
        <div style={{ maxWidth: 1160, margin: "0 auto" }}>
          <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", flexWrap: "wrap", gap: 16, marginBottom: 20 }}>
            <span style={{ fontFamily: "var(--font-playfair)", fontSize: 20, fontWeight: 700, color: "var(--green)", letterSpacing: "-0.01em" }}>Our Fable</span>
            <div style={{ display: "flex", gap: 28, flexWrap: "wrap" }}>
              <Link href="/how-it-works" className="nav-link" style={{ fontSize: 13 }}>How it works</Link>
              <Link href="/privacy" className="nav-link" style={{ fontSize: 13 }}>Privacy</Link>
              <Link href="/terms" className="nav-link" style={{ fontSize: 13 }}>Terms</Link>
            </div>
          </div>
          <div style={{ borderTop: "1px solid var(--border)", paddingTop: 16, display: "flex", justifyContent: "space-between", flexWrap: "wrap", gap: 8 }}>
            <p style={{ fontSize: 12, color: "var(--text-3)" }}>Private by design. For families. Not followers.</p>
            <p style={{ fontSize: 12, color: "var(--text-4)" }}>© 2026 Our Fable</p>
          </div>
        </div>
      </footer>

      <style>{`
        @media (max-width: 860px) { .security-intro { grid-template-columns: 1fr !important; gap: 32px !important; } }
      `}</style>
    </div>
  );
}
