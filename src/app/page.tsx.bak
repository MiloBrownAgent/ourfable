          .hero-section { padding: 100px 20px 60px !important; }
          .proof-strip { gap: 14px !important; padding: 14px 20px !important; }
          .proof-strip span { font-size: 12px !important; }
          .section-inner { padding-left: 20px !important; padding-right: 20px !important; }
          .security-intro { grid-template-columns: 1fr !important; gap: 32px !important; }
        }
      `}</style>

      {/* ── NAV ── */}
      <nav style={{
        position: "fixed", top: 0, left: 0, right: 0, zIndex: 100, height: 64,
        display: "flex", alignItems: "center", padding: "0 40px",
        background: scrolled ? "rgba(253,251,247,0.96)" : "transparent",
