              Reserve your spot
            </Link>
          </div>
        </div>
      </nav>

      {/* ── HERO ── */}
      <section id="waitlist" className="hero-section" style={{ padding: "148px 40px 100px", maxWidth: 1160, margin: "0 auto" }}>
        <div className="hero-grid" style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 80, alignItems: "center" }}>
          {/* Left: copy */}
          <div>
            <div style={{ marginBottom: 20, animation: "revealUp 0.5s ease both" }}>
              <span className="chip chip-green" style={{ fontSize: 12 }}>Private · Permanent · Personal</span>
